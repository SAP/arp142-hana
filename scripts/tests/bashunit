  local -a tests_by_line=()
  local _line_and_test
  while IFS= read -r _line_and_test; do
    [ -z "$_line_and_test" ] && continue
    local _tln="${_line_and_test%%|*}"
    local _tinfo="${_line_and_test#*|}"
    if [ -n "${tests_by_line[_tln]:-}" ]; then
